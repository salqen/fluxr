# ─────────────────────────────────────────────────────────────
# fluxr — environment variables
# Copy to .env locally, or set these in Railway → Variables.
# ─────────────────────────────────────────────────────────────

# Meta / Facebook app (developers.facebook.com → your app → Settings → Basic)
META_APP_ID=996438119804252
META_APP_SECRET=                     # REQUIRED — App Secret from Meta dashboard

# OAuth redirect — MUST exactly match the URI registered in the Meta app
# Local:   http://localhost:5000/auth/callback
# Railway: https://<your-app>.up.railway.app/auth/callback
REDIRECT_URI=http://localhost:5000/auth/callback

# Public base URL of this server (used to build media URLs for the IG API).
# Must be HTTPS and publicly reachable for publishing to work.
# Local:   http://localhost:5000
# Railway: https://<your-app>.up.railway.app
BASE_URL=http://localhost:5000

# Flask session signing key. Set a STABLE random value or users get logged
# out on every restart. Generate one:  python -c "import secrets;print(secrets.token_hex(32))"
SECRET_KEY=

# Anthropic API key — enables the AI caption generator (console.anthropic.com)
ANTHROPIC_API_KEY=

# Optional — where runtime data is stored (defaults to /tmp/fluxr_data).
# On Railway /tmp resets on every redeploy; mount a volume for persistence.
# DATA_DIR=/data/fluxr

# Port (Railway sets this automatically; default 5000 locally)
# PORT=5000
